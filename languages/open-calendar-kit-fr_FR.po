msgid "Use WordPress language"
msgstr "Utiliser la langue de WordPress"

msgid "Plugin language"
msgstr "Langue de l’extension"

msgid "Use the website language by default, or choose a language for OpenCalendarKit only."
msgstr "Utilisez la langue du site par défaut ou choisissez une langue uniquement pour OpenCalendarKit."

msgid "Settings"
msgstr "Paramètres"

msgid "Show status today by default"
msgstr "Afficher le statut du jour par défaut"

msgid "Allow the status shortcode to output by default."
msgstr "Autoriser l’affichage du shortcode de statut par défaut."

msgid "Show calendar legend by default"
msgstr "Afficher la légende du calendrier par défaut"

msgid "Display the open/closed legend below the calendar unless a shortcode overrides it."
