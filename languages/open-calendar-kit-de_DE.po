#. Plugin Name of the plugin
#: open-calendar-kit.php
#: includes/Admin/class-opencalendarkit-admin-openinghours.php:25
#: includes/Admin/class-opencalendarkit-admin-openinghours.php:26
msgid "OpenCalendarKit"
msgstr "OpenCalendarKit"

#. Description of the plugin
#: open-calendar-kit.php
msgid ""
"Public WordPress plugin for opening hours, closed days, monthly calendars, "
"calendar events, event notices, and optional status displays."
msgstr ""
"Öffentliches WordPress-Plugin für Öffnungszeiten, Schließtage, monatliche "
"Kalender, Kalender-Events, Event-Hinweise und optionale Statusanzeigen."

#. Author of the plugin
#: open-calendar-kit.php
msgid "Jörn / ChatGPT"
msgstr "Jörn / ChatGPT"

#: includes/Admin/class-opencalendarkit-admin-calendarevents.php:111
msgid "Calendar events saved."
msgstr "Kalender-Events gespeichert."

#: includes/Admin/class-opencalendarkit-admin-calendarevents.php:114
msgid "Calendar Events"
msgstr "Kalender-Events"

#: includes/Admin/class-opencalendarkit-admin-calendarevents.php:116
msgid ""
"Manage highlighted event dates for the frontend calendar. The shortcode "
"[openkit_calendar_event] renders the event text for the current day or for a "
"requested date. Only one event is stored per day; if a date is entered more "
"than once, the last row wins."
msgstr ""
"Verwalte hervorgehobene Event-Tage für den Frontend-Kalender. Der Shortcode "
"[openkit_calendar_event] gibt den Event-Text für den aktuellen Tag oder für "
"ein angefordertes Datum aus. Pro Tag wird nur ein Event gespeichert; wenn "
"ein Datum mehrfach eingetragen wird, gilt die letzte Zeile."

