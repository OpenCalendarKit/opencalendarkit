#. Plugin Name of the plugin
#: open-calendar-kit.php
#: includes/Admin/class-opencalendarkit-admin-openinghours.php:25
#: includes/Admin/class-opencalendarkit-admin-openinghours.php:26
msgid "OpenCalendarKit"
msgstr "OpenCalendarKit"

#. Description of the plugin
#: open-calendar-kit.php
msgid ""
"Lightweight business-hours plugin for opening hours, status today, closed "
"days, special opening times, and calendar events."
msgstr ""
"Leichtgewichtiges Plugin für Öffnungszeiten, Status heute, Schließtage, "
"besondere Öffnungszeiten und Kalender-Events."

#. Author of the plugin
#: open-calendar-kit.php
msgid "Jörn / ChatGPT"
msgstr "Jörn / ChatGPT"

#: includes/Admin/class-opencalendarkit-admin-calendarevents.php:109
